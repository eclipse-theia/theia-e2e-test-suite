{
  "private": true,
  "name": "theia-e2e-test-suite",
  "version": "1.46.1",
  "license": "EPL-2.0 OR GPL-2.0 WITH Classpath-exception-2.0",
  "scripts": {
    "prepare": "npm run clean && npm run build",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "build": "tsc --incremental && if-env SKIP_CHROMIUM_INSTALLATION=1 && echo 'Skipping chromium install' || npx playwright install chromium",
    "ui-tests": "playwright test --config=./configs/playwright.config.ts --project=Browser",
    "ui-tests-electron": "USE_ELECTRON=true playwright test --config=./configs/playwright.config.ts --project=Electron",
    "ui-tests-ci": "playwright test --config=./configs/playwright.ci.config.ts --project=Browser",
    "ui-tests-ci-electron": "USE_ELECTRON=true playwright test --config=./configs/playwright.ci.config.ts --project=Electron",
    "ui-tests-headful": "playwright test --config=./configs/playwright.headful.config.ts --project=Browser",
    "ui-tests-report-generate": "allure generate ./allure-results --clean -o allure-results/allure-report",
    "ui-tests-report": "npm run ui-tests-report-generate && allure open allure-results/allure-report",
    "performance": "npm run performance-on-chromium",
    "performance-on-chromium": "playwright test --config=./configs/performance.config.ts --project=Browser",
    "performance-on-electron": "USE_ELECTRON=true playwright test --config=./configs/performance.config.ts --project=Electron",
    "performance-report": "npm run performance-report-chromium",
    "performance-report-chromium": "node lib/scripts/performance-report.js --performanceMetricsPath performance-metrics/Browser --performancePublishPath=performance/chromium",
    "performance-report-electron": "node lib/scripts/performance-report.js --performanceMetricsPath performance-metrics/Electron --performancePublishPath=performance/electron"
  },
  "dependencies": {
    "@playwright/test": "^1.47.0",
    "@theia/playwright": "^1.69.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.1",
    "@types/node-fetch": "^2.6.4",
    "@types/yargs": "^17.0.24",
    "allure-commandline": "^2.23.1",
    "allure-playwright": "^2.5.0",
    "fs-extra": "^11.1.1",
    "if-env": "^1.0.4",
    "node-fetch": "^2.6.7",
    "rimraf": "^5.0.0",
    "typescript": "~5.6.0",
    "yargs": "^17.7.2"
  }
}
